# Docker Sync Engine - 环境变量配置模板
# 复制此文件并重命名为 .env，然后填写实际值

# GitHub Container Registry 访问令牌
# 获取方式：https://github.com/settings/tokens
# 需要的权限: read:packages, write:packages, delete:packages
GHCR_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Docker Hub 配置（可选，如果需要更高的 API 限额）
# 注册地址: https://hub.docker.com/
# DOCKERHUB_USERNAME=your_dockerhub_username
# DOCKERHUB_PASSWORD=your_dockerhub_password
# DOCKERHUB_TOKEN=your_dockerhub_token

# GitHub 相关配置
GITHUB_OWNER=freemankevin
GITHUB_REGISTRY=ghcr.io

# 日志级别（可选）
# 可选项: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# 并发配置（可选）
# MAX_WORKERS=5
# MAX_WORKERS_SYNC=3

# 重试配置（可选）
# MAX_RETRIES=3
# RETRY_DELAY=2.0
